{
  "name": "agora-mvp",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "AGORA — a resilient multi-agent operating system built on Aegis and TrueFoundry.",
  "scripts": {
    "dev": "bun run --watch src/agora/server.ts",
    "start": "bun run src/agora/server.ts",
    "demo": "bun run src/agora/demo.ts",
    "agora:test": "bun test src/agora",
    "build": "bun build ./src/server/index.ts --outdir dist --target bun",
    "test": "bun test",
    "test:integration": "bun test tests/integration",
    "test:chaos": "bun test tests/chaos",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "chaos:demo": "bun run src/chaos/scenarios.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@openai/agents": "^0.1.0",
    "hono": "^4.6.0",
    "openai": "^5.0.0",
    "p-retry": "^6.2.0",
    "p-timeout": "^6.1.4",
    "toxiproxy-node-client": "^2.0.6",
    "ulid": "^2.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0",
    "@biomejs/biome": "^1.9.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
